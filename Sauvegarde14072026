<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Suivi Mensuel Budget Local</title>
    
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Suivi Budget">
    <meta name="mobile-web-app-capable" content="yes">

    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='20' fill='%232c3e50'/><rect x='20' y='20' width='60' height='60' rx='8' fill='%23bdc3c7'/><circle cx='50' cy='50' r='18' fill='%237f8c8d'/><circle cx='50' cy='50' r='12' fill='%2334495e'/><path d='M50,38 L50,44 M50,56 L50,62 M38,50 L44,50 M56,50 L62,50' stroke='%23ffffff' stroke-width='3' stroke-linecap='round'/><circle cx='42' cy='42' r='2' fill='%232ecc71'/></svg>">
    <link class="apple-touch-icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='20' fill='%232c3e50'/><rect x='20' y='20' width='60' height='60' rx='8' fill='%23bdc3c7'/><circle cx='50' cy='50' r='18' fill='%237f8c8d'/><circle cx='50' cy='50' r='12' fill='%2334495e'/><path d='M50,38 L50,44 M50,56 L50,62 M38,50 L44,50 M56,50 L62,50' stroke='%23ffffff' stroke-width='3' stroke-linecap='round'/><circle cx='42' cy='42' r='2' fill='%232ecc71'/></svg>">

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <!-- Librairie locale pour générer le PDF proprement -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

    <style>
        :root {
            --primary: #2ecc71;
            --danger: #e74c3c;
            --warning: #f39c12;
            --dark: #2c3e50;
            --light: #f8f9fa;
            --accent: #3498db;
        }

        * { 
            box-sizing: border-box; 
            margin: 0; 
            padding: 0; 
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; 
            -webkit-tap-highlight-color: transparent;
        }
        
        body { 
            background-color: #f0f2f5; 
            color: var(--dark); 
            overflow-x: hidden;
            position: fixed;
            width: 100%;
            height: 100%;
            transition: background-color 0.25s ease, color 0.25s ease;
        }

        /* --- CONTENEUR SWIPER --- */
        .swiper-container {
            display: flex;
            width: 200vw;
            height: 100vh;
            transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            will-change: transform;
        }

        .view-page {
            width: 100vw;
            height: 100vh;
            overflow-y: auto;
            padding: 15px;
            padding-bottom: env(safe-area-inset-bottom, 30px);
        }

        .swipe-dots {
            display: flex;
            justify-content: center;
            gap: 8px;
            margin-bottom: 15px;
            margin-top: 5px;
        }

        .dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background-color: #cbd5e1;
            transition: background-color 0.3s;
        }

        .dot.active {
            background-color: var(--accent);
        }

        /* --- SPLASH SCREEN / LOADING --- */
        #splash-screen {
            position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
            background-color: #1a252f;
            display: flex; flex-direction: column; justify-content: center; align-items: center;
            z-index: 9999; transition: opacity 0.5s ease, visibility 0.5s; overflow: hidden;
        }

        .splash-container { position: relative; width: 200px; height: 200px; display: flex; justify-content: center; align-items: center; }
        .safe-door { transform-origin: 22px 50px; animation: openSafe 1.2s cubic-bezier(0.4, 0, 0.2, 1) forwards 0.3s; }
        .bill { opacity: 0; transform-origin: center; animation: flyMoney 1.2s cubic-bezier(0.19, 1, 0.22, 1) forwards 0.7s; }
        .bill-2 { animation-delay: 0.85s; }
        .bill-3 { animation-delay: 1s; }

        @keyframes openSafe { 0% { transform: rotateY(0deg); } 100% { transform: rotateY(-75deg) scaleX(0.9); filter: drop-shadow(8px 4px 6px rgba(0,0,0,0.4)); } }
        @keyframes flyMoney { 0% { transform: translate(0, 0) scale(0.3) rotate(0deg); opacity: 0; } 30% { opacity: 1; } 100% { transform: translate(var(--x), var(--y)) scale(1.1) rotate(var(--r)); opacity: 0; } }
        @keyframes fadeInText { to { opacity: 1; transform: translateY(0); } }

        .splash-title { color: white; margin-top: 25px; font-size: 1.8rem; font-weight: 900; letter-spacing: 1.5px; text-transform: uppercase; opacity: 0; transform: translateY(15px); animation: fadeInText 0.6s ease forwards 0.5s; text-align: center; }
        .splash-subtitle { color: #bdc3c7; font-size: 0.85rem; font-weight: bold; letter-spacing: 2px; text-transform: uppercase; margin-top: 5px; opacity: 0; transform: translateY(10px); animation: fadeInText 0.6s ease forwards 0.7s; text-align: center; }
        .splash-status { color: #2ecc71; margin-top: 20px; font-size: 0.95rem; font-weight: bold; letter-spacing: 1px; }

        .container { max-width: 500px; margin: 0 auto; }
        header { background: white; padding: 20px; border-radius: 15px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); margin-bottom: 15px; text-align: center; }
        h1 { font-size: 1.4rem; margin-bottom: 10px; color: var(--dark); }
        .month-selector-main { margin-bottom: 15px; display: flex; flex-direction: column; gap: 5px; }
        input[type="month"], select, input[type="text"], input[type="number"], button { padding: 12px; border-radius: 10px; border: 1px solid #ccc; font-size: 1rem; outline: none; width: 100%; background: white; }
        .budget-setup { display: flex; gap: 10px; margin-bottom: 10px; }
        .budget-setup input { flex: 1; }
        .budget-setup button { width: auto; padding: 12px 20px; }
        .category-budget-toggle { background: none; color: var(--accent); font-size: 0.9rem; padding: 5px; width: auto; margin: 0 auto 10px auto; font-weight: 600; border: none; cursor: pointer; }
        .category-budget-panel { display: none; background: var(--light); padding: 15px; border-radius: 10px; margin-bottom: 15px; text-align: left; }
        .dispatch-info { background: #e8f4f8; padding: 10px; border-radius: 8px; margin-bottom: 15px; font-size: 0.9rem; font-weight: bold; display: flex; justify-content: space-between; color: #2980b9; }
        .dispatch-info.alert { background: #fdf2f2; color: var(--danger); }
        .category-budget-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
        .category-budget-row input { width: 100px; padding: 6px; border-radius: 6px; font-size: 0.9rem; text-align: right; }
        button { background: var(--primary); color: white; border: none; font-weight: bold; cursor: pointer; }
        button:active { opacity: 0.8; }
        .stats { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 15px; }
        .stat-box { padding: 10px; border-radius: 10px; background: var(--light); text-align: center; }
        .stat-box.alert { background: #fdf2f2; color: var(--danger); }
        .stat-box span { display: block; font-size: 0.8rem; text-transform: uppercase; color: #7f8c8d; }
        .stat-box strong { font-size: 1.2rem; }
        
        /* GAUGE STYLES */
        .live-gauges-container { margin-bottom: 15px; }
        .gauge-item { margin-bottom: 12px; }
        .gauge-info { display: flex; justify-content: space-between; font-size: 0.85rem; margin-bottom: 4px; font-weight: 600; }
        .gauge-bar-bg { background: #e9ecef; height: 10px; border-radius: 5px; overflow: hidden; }
        .gauge-bar-fill { height: 100%; width: 0%; border-radius: 5px; transition: width 0.4s ease; }
        .gauge-green { background-color: var(--primary); }
        .gauge-orange { background-color: var(--warning); }
        .gauge-red { background-color: var(--danger); }
        
        .card { background: white; padding: 15px; border-radius: 15px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); margin-bottom: 15px; }
        .list-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
        .list-sort { width: auto; padding: 6px 10px; font-size: 0.85rem; border-radius: 8px; background: var(--light); }
        .form-row { display: flex; gap: 10px; margin-bottom: 10px; }
        .form-row * { flex: 1; }
        .btn-block { width: 100%; display: block; }
        .shopping-list { max-height: 250px; overflow-y: auto; }
        .item { display: flex; justify-content: space-between; align-items: center; padding: 12px 10px; border-bottom: 1px solid #eee; }
        .item-details { display: flex; flex-direction: column; text-align: left; }
        .item-name { font-weight: 600; }
        .item-meta { font-size: 0.85rem; color: #7f8c8d; }
        .tag { display: inline-block; background: #e1f5fe; color: var(--accent); padding: 2px 6px; border-radius: 5px; font-size: 0.75rem; margin-top: 2px; font-weight: bold; }
        .btn-delete { background: none; color: var(--danger); font-size: 1.1rem; width: auto; border: none; }
        .checkbox-group { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; background: var(--light); padding: 10px; border-radius: 10px; }
        .checkbox-label { display: flex; align-items: center; gap: 6px; font-size: 0.9rem; }
        .chart-container { position: relative; margin: 15px 0; width: 100%; height: 280px; }
        .clear-btn { background: var(--danger); margin-top: 10px; }
        .backup-btn { background: var(--accent); margin-top: 10px; }

        /* --- INTERFACE MODALE POPUP PDF --- */
        .modal {
            display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.5); z-index: 10000; justify-content: center; align-items: center;
            padding: 20px;
        }
        .modal-content {
            background: white; padding: 20px; border-radius: 15px; max-width: 400px; width: 100%;
            box-shadow: 0 10px 25px rgba(0,0,0,0.2); text-align: center;
        }
        .modal h3 { margin-bottom: 15px; font-size: 1.2rem; }
        .modal .months-list { max-height: 200px; overflow-y: auto; margin: 15px 0; text-align: left; border: 1px solid #eee; padding: 10px; border-radius: 8px; }
        .modal-buttons { display: flex; gap: 10px; margin-top: 15px; }
        .btn-secondary { background: #95a5a6; }

        /* --- RÉGLAGE : INTERRUPTEUR MODE SOMBRE --- */
        .settings-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
        .settings-row span { font-weight: 600; font-size: 0.95rem; }
        .switch { position: relative; display: inline-block; width: 46px; height: 26px; flex-shrink: 0; }
        .switch input { opacity: 0; width: 0; height: 0; }
        .slider { position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: #ccc; transition: .3s; border-radius: 26px; }
        .slider:before { position: absolute; content: ""; height: 20px; width: 20px; left: 3px; bottom: 3px; background-color: white; transition: .3s; border-radius: 50%; }
        .switch input:checked + .slider { background-color: var(--accent); }
        .switch input:checked + .slider:before { transform: translateX(20px); }

        /* --- MODE SOMBRE --- */
        body.dark-mode { background-color: #10161f; color: #ecf0f1; }
        body.dark-mode header,
        body.dark-mode .card,
        body.dark-mode .modal-content { background: #1c2431; color: #ecf0f1; box-shadow: 0 4px 6px rgba(0,0,0,0.3); }
        body.dark-mode h1, body.dark-mode h3 { color: #ecf0f1; }
        body.dark-mode .stat-box,
        body.dark-mode .category-budget-panel,
        body.dark-mode .checkbox-group,
        body.dark-mode .list-sort { background: #263042; color: #ecf0f1; }
        body.dark-mode .stat-box span { color: #9aa7b8; }
        body.dark-mode .stat-box.alert,
        body.dark-mode .dispatch-info.alert { background: #3a2020; color: #ff8a80; }
        body.dark-mode .dispatch-info { background: #1f3542; color: #6ec6f1; }
        body.dark-mode input[type="month"],
        body.dark-mode select,
        body.dark-mode input[type="text"],
        body.dark-mode input[type="number"] { background: #263042; color: #ecf0f1; border-color: #3b4a5e; }
        body.dark-mode .item { border-bottom-color: #2c3648; }
        body.dark-mode .item-meta { color: #9aa7b8; }
        body.dark-mode .tag { background: #1f3542; color: #6ec6f1; }
        body.dark-mode .gauge-bar-bg { background: #2c3648; }
        body.dark-mode .dot { background-color: #2c3648; }
        body.dark-mode .dot.active { background-color: var(--accent); }
        body.dark-mode .category-budget-toggle { color: #6ec6f1; }
        body.dark-mode .modal { background: rgba(0,0,0,0.7); }
        body.dark-mode .months-list { border-color: #2c3648; }
    </style>
</head>
<body>

<!-- LOADING / SPLASH SCREEN -->
<div id="splash-screen">
    <div class="splash-container">
        <svg width="100%" height="100%" viewBox="0 0 100 100" style="perspective: 500px;">
            <rect x="23" y="23" width="54" height="54" rx="4" fill="#111827"/>
            <circle cx="50" cy="55" r="15" fill="#f1c40f" opacity="0.8"/>
            <g class="bill bill-1" style="--x: -55px; --y: -65px; --r: -45deg;"><rect x="42" y="45" width="16" height="9" rx="1.5" fill="#2ecc71" stroke="#27ae60" stroke-width="1"/></g>
            <g class="bill bill-2" style="--x: 65px; --y: -50px; --r: 35deg;"><rect x="44" y="46" width="16" height="9" rx="1.5" fill="#2ecc71" stroke="#27ae60" stroke-width="1"/></g>
            <g class="bill bill-3" style="--x: 10px; --y: -85px; --r: -15deg;"><rect x="43" y="44" width="16" height="9" rx="1.5" fill="#2ecc71" stroke="#27ae60" stroke-width="1"/></g>
            <rect x="15" y="15" width="70" height="70" rx="12" fill="none" stroke="#7f8c8d" stroke-width="6"/>
            <g class="safe-door">
                <rect x="20" y="20" width="60" height="60" rx="8" fill="#bdc3c7" stroke="#95a5a6" stroke-width="1.5"/>
                <circle cx="54" cy="50" r="15" fill="#7f8c8d" stroke="#34495e" stroke-width="2"/>
                <path d="M54,38 L54,42 M54,58 L54,62 M42,50 L46,50 M62,50 L66,50" stroke="#ffffff" stroke-width="2"/>
            </g>
        </svg>
    </div>
    <div class="splash-title">Budget Local</div>
    <div class="splash-subtitle">BY MCD Studio</div>
    <div class="splash-status" id="splash-status">Chargement...</div>
</div>

<!-- POPUP MODALE EXPORT PDF -->
<div class="modal" id="pdf-modal">
    <div class="modal-content">
        <h3>💾 Sauvegarde & Export PDF</h3>
        <p style="font-size:0.85rem; color:#7f8c8d; margin-bottom: 10px;">Sélectionnez les mois à inclure dans le rapport (Synthèse par famille uniquement) :</p>
        <div class="months-list" id="pdf-months-list"></div>
        <div class="modal-buttons">
            <button class="btn-secondary" onclick="closePdfModal()">Annuler</button>
            <button onclick="generatePDFReport()">Générer le PDF</button>
        </div>
    </div>
</div>

<!-- CONTENEUR PRINCIPAL SWIPER -->
<div class="swiper-container" id="swiperContainer">

    <!-- PAGE 1 : SUIVI DES TRANSACTIONS -->
    <div class="view-page" id="page-courses">
        <div class="container">
            <div class="swipe-dots">
                <div class="dot active"></div>
                <div class="dot"></div>
            </div>

            <header>
                <h1>💼 Suivi Mensuel Budget</h1>
                <div class="month-selector-main">
                    <input type="month" id="current-month-input" onchange="changeCurrentMonth()">
                </div>
                <div class="budget-setup">
                    <input type="number" id="initial-budget" placeholder="Fixer le budget global (€)" oninput="calculateDispatchRemaining()">
                    <button onclick="setBudget()">OK</button>
                </div>
                <button class="category-budget-toggle" onclick="toggleCategoryPanel()">⚙️ Ajuster les budgets par familles</button>
                <div class="category-budget-panel" id="category-budget-panel"></div>
                <div class="stats">
                    <div class="stat-box"><span>Total Dépenses</span><strong id="total-cart">0.00 €</strong></div>
                    <div class="stat-box" id="remaining-box"><span>Reste Global</span><strong id="total-remaining">0.00 €</strong></div>
                </div>
            </header>

            <!-- GAUJES FAMILLES -->
            <div class="card" id="gauges-card" style="display:none;">
                <h3>Suivi des Budgets Familles</h3>
                <div class="live-gauges-container" id="live-gauges-container"></div>
            </div>

            <!-- AJOUT DÉPENSE -->
            <div class="card">
                <h3>Nouvelle Dépense</h3>
                <div class="form-row" style="margin-top:10px;">
                    <input type="text" id="item-name" placeholder="Article / Libellé">
                    <input type="number" id="item-price" placeholder="Prix (€)" step="0.01">
                </div>
                <div class="form-row">
                    <select id="item-category"></select>
                </div>
                <button class="btn-block" onclick="addItem()">Ajouter la dépense</button>
            </div>

            <!-- HISTORIQUE DES TRANSACTIONS VISUELLES SUR TÉLÉPHONE -->
            <div class="card">
                <div class="list-header">
                    <h3>Dépenses enregistrées</h3>
                    <select id="sort-order" class="list-sort" onchange="updateUI()">
                        <option value="date">📅 Date de saisie</option>
                        <option value="category">🏷️ Regrouper par Famille</option>
                    </select>
                </div>
                <div class="shopping-list" id="shopping-list"></div>
            </div>
        </div>
    </div>

    <!-- PAGE 2 : ANALYSE & PARAMÈTRES -->
    <div class="view-page" id="page-history">
        <div class="container">
            <div class="swipe-dots">
                <div class="dot"></div>
                <div class="dot active"></div>
            </div>

            <header>
                <h1>📊 Analyse & Historique</h1>
            </header>
            <div class="card"><div class="checkbox-group" id="months-checkboxes"></div></div>
            <div class="card">
                <h3>Répartition par Catégorie</h3>
                <div class="chart-container"><canvas id="categoryChart"></canvas></div>
            </div>
            <div class="card">
                <h3 id="annual-chart-title">Récapitulatif Annuel</h3>
                <div class="chart-container"><canvas id="annualChart"></canvas></div>
            </div>
            
            <!-- PARAMÈTRES ET SAUVEGARDES LOCALES -->
            <div class="card">
                <h3>Paramètres & Sauvegardes</h3>

                <div class="settings-row" style="margin-top:15px;">
                    <span>🌙 Mode sombre</span>
                    <label class="switch">
                        <input type="checkbox" id="dark-mode-toggle" onchange="toggleDarkMode()">
                        <span class="slider"></span>
                    </label>
                </div>

                <button class="btn-block backup-btn" onclick="openPdfModal()" style="margin-top:15px;">💾 Sauvegarde : Générer un Rapport PDF</button>

                <button class="btn-block backup-btn" onclick="exportCSV()" style="margin-top:10px;">📤 Exporter les données (CSV)</button>

                <input type="file" id="import-csv-input" accept=".csv,text/csv,text/comma-separated-values,application/csv,text/plain,*/*" style="display:none;" onchange="importCSV(event)">
                <button class="btn-block backup-btn" onclick="document.getElementById('import-csv-input').click()" style="margin-top:10px;">📥 Importer des données (CSV)</button>

                <button class="btn-block clear-btn" onclick="clearAllData()" style="margin-top:10px;">Réinitialiser TOUTES les données locales</button>
            </div>
        </div>
    </div>

</div>

<!-- ESPACE CACHÉ DE CONSTRUCTION HTML DU PDF -->
<div id="pdf-template-container" style="display: none;"></div>

<script>
    const MONTH_NAMES = ["Janvier", "Février", "Mars", "Avril", "Mai", "Juin", "Juillet", "Août", "Septembre", "Octobre", "Novembre", "Décembre"];
    const CATEGORIES = [
        { value: "Alimentaire", label: "🍎 Alimentaire" }, { value: "Bricolage", label: "🔨 Bricolage" },
        { value: "Cadeaux", label: "🎁 Cadeaux" }, { value: "Carburant", label: "⛽ Carburant" },
        { value: "Enfants", label: "👶 Enfants" }, { value: "Frais auto", label: "🚗 Frais auto" },
        { value: "Frais maison", label: "🏠 Frais maison" }, { value: "Loisirs", label: "🎮 Loisirs" },
        { value: "Professionnel", label: "💼 Professionnel" }, { value: "Santé", label: "🩺 Santé" },
        { value: "Sport", label: "⚽ Sport" }, { value: "Sorties", label: "🎉 Sorties" },
        { value: "Transport", label: "🚌 Transport" }, { value: "Vêtements", label: "👕 Vêtements" }
    ];

    let appData = {};
    let selectedMonthId = new Date().toISOString().slice(0, 7);

    // --- ENREGISTREMENT ET NAVIGATION SWIPE (INCHANGÉS) ---
    const swiperContainer = document.getElementById('swiperContainer');
    let startX = 0, currentX = 0, isTracking = false, currentViewIndex = 0; 

    window.addEventListener('touchstart', (e) => { startX = e.touches[0].clientX; isTracking = true; }, { passive: true });
    window.addEventListener('touchmove', (e) => { if (!isTracking) return; currentX = e.touches[0].clientX; }, { passive: true });
    window.addEventListener('touchend', () => {
        if (!isTracking) return;
        isTracking = false;
        let deltaX = startX - currentX;
        if (Math.abs(deltaX) > 60 && currentX !== 0) {
            if (deltaX > 0 && currentViewIndex === 0) {
                currentViewIndex = 1;
                swiperContainer.style.transform = "translateX(-100vw)";
                refreshHistoryCheckboxes(); 
                updateAnalysis();
            } else if (deltaX < 0 && currentViewIndex === 1) {
                currentViewIndex = 0;
                swiperContainer.style.transform = "translateX(0vw)";
                updateUI();
            }
        }
        startX = 0; currentX = 0;
    });

    // --- STOCKAGE LOCAL IMPÉRATIF UNIQUE ---
    function loadDataLocal() {
        appData = JSON.parse(localStorage.getItem('budget_app_data_local')) || {};
    }

    function saveDataLocal() {
        localStorage.setItem('budget_app_data_local', JSON.stringify(appData));
    }

    function initCategorySelect() {
        const select = document.getElementById('item-category');
        if(select) select.innerHTML = CATEGORIES.map(cat => `<option value="${cat.value}">${cat.label}</option>`).join('');
    }

    function toggleCategoryPanel() {
        const panel = document.getElementById('category-budget-panel');
        if(panel) panel.style.display = (panel.style.display === 'block') ? 'none' : 'block';
    }

    function renderCategoryBudgetSettings() {
        const panel = document.getElementById('category-budget-panel');
        if(!panel) return;
        const data = getMonthData(selectedMonthId);
        panel.innerHTML = `<div class="dispatch-info" id="dispatch-indicator"><span>Reste à distribuer :</span><span id="dispatch-left">0.00 €</span></div>`;

        CATEGORIES.forEach(cat => {
            const currentVal = data.categoryBudgets[cat.value] || '';
            panel.innerHTML += `
                <div class="category-budget-row">
                    <label>${cat.label}</label>
                    <input type="number" class="cat-budget-input" data-cat="${cat.value}" value="${currentVal}" placeholder="0" oninput="calculateDispatchRemaining()" onchange="saveCategoryBudgets()">
                </div>`;
        });
        calculateDispatchRemaining();
    }

    function calculateDispatchRemaining() {
        const inputBud = document.getElementById('initial-budget');
        const globalBudget = inputBud ? (parseFloat(inputBud.value) || 0) : 0;
        let totalAllocated = 0;
        document.querySelectorAll('.cat-budget-input').forEach(input => totalAllocated += parseFloat(input.value) || 0);
        const leftToDispatch = globalBudget - totalAllocated;
        
        const indicator = document.getElementById('dispatch-indicator');
        const leftEl = document.getElementById('dispatch-left');
        if(indicator && leftEl) {
            leftEl.innerText = `${leftToDispatch.toFixed(2)} € / ${globalBudget.toFixed(0)} €`;
            if (leftToDispatch < 0) indicator.classList.add('alert'); else indicator.classList.remove('alert');
        }
    }

    function saveCategoryBudgets() {
        const data = getMonthData(selectedMonthId);
        document.querySelectorAll('.cat-budget-input').forEach(input => {
            const cat = input.getAttribute('data-cat');
            const val = parseFloat(input.value);
            if(!isNaN(val) && val > 0) data.categoryBudgets[cat] = val; else delete data.categoryBudgets[cat];
        });
        saveDataLocal(); updateUI();
    }

    function changeCurrentMonth() {
        const cMonth = document.getElementById('current-month-input');
        if(cMonth) selectedMonthId = cMonth.value;
        renderCategoryBudgetSettings(); updateUI();
    }

    function getMonthData(monthId) {
        if (!appData[monthId]) appData[monthId] = { budget: 0, items: [], categoryBudgets: {} };
        if (!appData[monthId].categoryBudgets) appData[monthId].categoryBudgets = {};
        if (!Array.isArray(appData[monthId].items)) appData[monthId].items = [];
        return appData[monthId];
    }

    function updateUI() {
        try {
            const data = getMonthData(selectedMonthId);
            const initBud = document.getElementById('initial-budget');
            if(initBud) initBud.value = data.budget > 0 ? data.budget : '';
            
            const listDeco = document.getElementById('shopping-list');
            if(!listDeco) return;
            listDeco.innerHTML = '';
            
            let totalGlobal = 0;
            const categoryTotals = {};
            CATEGORIES.forEach(c => categoryTotals[c.value] = 0);

            let itemsToShow = [...data.items];
            const sortOrder = document.getElementById('sort-order') ? document.getElementById('sort-order').value : 'date';

            if (sortOrder === 'category') {
                itemsToShow.sort((a, b) => a.category.localeCompare(b.category));
            } else {
                itemsToShow.reverse();
            }

            itemsToShow.forEach((item) => {
                totalGlobal += item.price;
                if(categoryTotals[item.category] !== undefined) categoryTotals[item.category] += item.price;
                const catObj = CATEGORIES.find(c => c.value === item.category) || { label: item.category };
                const originalIndex = data.items.indexOf(item);

                listDeco.innerHTML += `
                    <div class="item">
                        <div class="item-details">
                            <span class="item-name">${item.name}</span>
                            <span class="item-meta">${item.price.toFixed(2)} € • <span class="tag">${catObj.label}</span></span>
                        </div>
                        <button class="btn-delete" onclick="removeItem(${originalIndex})">✕</button>
                    </div>`;
            });

            if(data.items.length === 0) listDeco.innerHTML = '<p style="text-align:center;color:#7f8c8d;padding:20px;">Aucune dépense.</p>';

            document.getElementById('total-cart').innerText = `${totalGlobal.toFixed(2)} €`;
            const remainingGlobal = data.budget - totalGlobal;
            document.getElementById('total-remaining').innerText = `${remainingGlobal.toFixed(2)} €`;
            
            const rbEl = document.getElementById('remaining-box');
            if (rbEl) { if (remainingGlobal < 0) rbEl.classList.add('alert'); else rbEl.classList.remove('alert'); }

            const gaugesContainer = document.getElementById('live-gauges-container');
            if(gaugesContainer) {
                gaugesContainer.innerHTML = '';
                let hasGauges = false;

                CATEGORIES.forEach(cat => {
                    const limit = data.categoryBudgets[cat.value] || 0;
                    const spent = categoryTotals[cat.value] || 0;
                    if (limit > 0 || spent > 0) {
                        hasGauges = true;
                        let pct = limit > 0 ? (spent / limit) * 100 : 0;
                        let colorClass = pct >= 100 ? "gauge-red" : (pct >= 70 ? "gauge-orange" : "gauge-green");
                        gaugesContainer.innerHTML += `
                            <div class="gauge-item">
                                <div class="gauge-info"><span>${cat.label}</span><span>${spent.toFixed(2)} € / ${limit > 0 ? limit+' € ('+pct.toFixed(0)+'%)' : 'Sans limite'}</span></div>
                                <div class="gauge-bar-bg"><div class="gauge-bar-fill ${colorClass}" style="width: ${limit > 0 ? Math.min(pct, 100) : 100}%;"></div></div>
                            </div>`;
                    }
                });
                document.getElementById('gauges-card').style.display = hasGauges ? 'block' : 'none';
            }
        } catch(e) { console.error(e); }
    }

    function setBudget() {
        const ibEl = document.getElementById('initial-budget');
        getMonthData(selectedMonthId).budget = ibEl ? (parseFloat(ibEl.value) || 0) : 0;
        saveDataLocal(); calculateDispatchRemaining(); updateUI();
    }

    // --- CRÉATION DE TRANSACTIONS ---
    function addItem() {
        const nameEl = document.getElementById('item-name');
        const priceEl = document.getElementById('item-price');
        const catEl = document.getElementById('item-category');
        
        const name = nameEl ? (nameEl.value.trim() || "Dépense sans nom") : "Dépense sans nom";
        const price = priceEl ? parseFloat(priceEl.value) : 0;
        const category = catEl ? catEl.value : CATEGORIES[0].value;
        if (isNaN(price) || price <= 0) return;

        getMonthData(selectedMonthId).items.push({ name, price, category });
        if(nameEl) nameEl.value = ''; if(priceEl) priceEl.value = '';
        saveDataLocal(); updateUI();
    }

    function removeItem(index) {
        getMonthData(selectedMonthId).items.splice(index, 1);
        saveDataLocal(); updateUI();
    }

    function refreshHistoryCheckboxes() {
        const container = document.getElementById('months-checkboxes');
        if(!container) return; container.innerHTML = '';
        Object.keys(appData).sort((a,b) => b.localeCompare(a)).forEach(mId => {
            const parts = mId.split('-');
            if(parts.length === 2) {
                container.innerHTML += `<label class="checkbox-label"><input type="checkbox" value="${mId}" class="month-cb" checked onchange="updateAnalysis()"> ${MONTH_NAMES[parseInt(parts[1])-1]} ${parts[0]}</label>`;
            }
        });
    }

    let myChart = null, myAnnualChart = null;
    function updateAnalysis() {
        try {
            const selectedMonths = Array.from(document.querySelectorAll('.month-cb:checked')).map(cb => cb.value);
            const totals = {}; CATEGORIES.forEach(c => totals[c.value] = 0);
            selectedMonths.forEach(mId => { if(appData[mId] && appData[mId].items) appData[mId].items.forEach(it => { if(totals[it.category] !== undefined) totals[it.category] += it.price; })});

            const ctx1 = document.getElementById('categoryChart');
            if (ctx1) {
                if (myChart) myChart.destroy();
                myChart = new Chart(ctx1.getContext('2d'), {
                    type: 'doughnut',
                    data: { labels: CATEGORIES.map(c => c.label), datasets: [{ data: CATEGORIES.map(c => totals[c.value]), backgroundColor: ['#2ecc71', '#f1c40f', '#e67e22', '#e74c3c', '#9b59b6', '#3498db', '#1abc9c', '#ff9ff3', '#ff6b6b', '#16a085', '#2c3e50', '#00d2d3', '#f39c12', '#95a5a6'] }] },
                    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom', labels: { boxWidth: 10, font: { size: 9 } } } } }
                });
            }

            const currentYear = selectedMonthId.split('-')[0];
            document.getElementById('annual-chart-title').innerText = `Suivi Annuel - ${currentYear}`;
            const annualTotals = Array(12).fill(0);
            Object.keys(appData).forEach(mId => { const p = mId.split('-'); if(p[0] === currentYear && appData[mId].items) { let sum = 0; appData[mId].items.forEach(i => sum += i.price); annualTotals[parseInt(p[1])-1] = sum; }});

            const ctx2 = document.getElementById('annualChart');
            if (ctx2) {
                if (myAnnualChart) myAnnualChart.destroy();
                myAnnualChart = new Chart(ctx2.getContext('2d'), {
                    type: 'bar',
                    data: { labels: MONTH_NAMES.map(m => m.substring(0, 4)+'.'), datasets: [{ data: annualTotals, backgroundColor: 'rgba(52, 152, 219, 0.75)' }] },
                    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
                });
            }
        } catch(e) { console.error(e); }
    }

    // --- GESTION DU POPUP MODAL SAUVEGARDE PDF ---
    function openPdfModal() {
        const listContainer = document.getElementById('pdf-months-list');
        if(!listContainer) return;
        listContainer.innerHTML = '';
        
        const registeredMonths = Object.keys(appData).sort((a,b) => a.localeCompare(b)); // Rendu chronologique
        if(registeredMonths.length === 0) {
            listContainer.innerHTML = '<p style="font-size:0.9rem;color:#7f8c8d;text-align:center;padding:10px;">Aucune donnée mensuelle enregistrée.</p>';
        } else {
            registeredMonths.forEach(mId => {
                const parts = mId.split('-');
                const label = `${MONTH_NAMES[parseInt(parts[1])-1]} ${parts[0]}`;
                listContainer.innerHTML += `<label class="checkbox-label" style="margin-bottom:8px;"><input type="checkbox" value="${mId}" class="pdf-cb" checked> ${label}</label>`;
            });
        }
        document.getElementById('pdf-modal').style.display = 'flex';
    }

    function closePdfModal() {
        document.getElementById('pdf-modal').style.display = 'none';
    }

    // --- COPIE CONFORME SYNTHÉTIQUE DU RAPPORT EN PDF ---
    function generatePDFReport() {
        const selectedMonths = Array.from(document.querySelectorAll('.pdf-cb:checked')).map(cb => cb.value);
        if(selectedMonths.length === 0) { alert("Veuillez cocher au moins un mois à exporter."); return; }

        const template = document.getElementById('pdf-template-container');
        template.innerHTML = ''; 

        let htmlContent = `
            <div style="padding: 25px; font-family: Helvetica, Arial, sans-serif; color: #2c3e50; background: white;">
                <h1 style="text-align: center; font-size: 20px; margin-bottom: 5px; color: #1a252f; text-transform: uppercase; letter-spacing: 1px;">Rapport de Sauvegarde Budgétaire</h1>
                <p style="text-align: center; font-size: 11px; color: #7f8c8d; margin-bottom: 25px;">Exporté localement le ${new Date().toLocaleDateString('fr-FR')}</p>
        `;

        selectedMonths.forEach((mId, idx) => {
            const data = appData[mId];
            const parts = mId.split('-');
            const labelMois = `${MONTH_NAMES[parseInt(parts[1])-1].toUpperCase()} ${parts[0]}`;
            
            let totalSpent = 0;
            const categoryTotals = {};
            CATEGORIES.forEach(c => categoryTotals[c.value] = 0);
            if(data.items) {
                data.items.forEach(it => {
                    totalSpent += it.price;
                    if(categoryTotals[it.category] !== undefined) categoryTotals[it.category] += it.price;
                });
            }
            const remainingGlobal = data.budget - totalSpent;

            // Saut de page automatique entre chaque mois
            if (idx > 0) {
                htmlContent += `<div style="page-break-before: always;"></div>`;
            }

            htmlContent += `
                <div style="border: 1px solid #e1e8ed; border-radius: 12px; padding: 20px; margin-bottom: 25px; background: #fff;">
                    <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #34495e; padding-bottom: 10px; margin-bottom: 15px;">
                        <h2 style="margin:0; font-size: 16px; color: #34495e;">📊 ${labelMois}</h2>
                        <span style="font-size: 11px; font-weight: bold; padding: 4px 8px; border-radius: 6px; background: ${remainingGlobal >= 0 ? '#e8f4f8' : '#fdf2f2'}; color: ${remainingGlobal >= 0 ? '#2980b9' : '#e74c3c'};">
                            Reste global : ${remainingGlobal.toFixed(2)} €
                        </span>
                    </div>
                    
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 20px; background: #f8f9fa; padding: 12px; border-radius: 8px;">
                        <div style="text-align: center;"><span style="font-size: 9px; color:#7f8c8d; text-transform:uppercase; display:block;">Budget Fixé</span><strong style="font-size: 14px;">${data.budget.toFixed(2)} €</strong></div>
                        <div style="text-align: center;"><span style="font-size: 9px; color:#7f8c8d; text-transform:uppercase; display:block;">Total Dépenses</span><strong style="font-size: 14px; color:${totalSpent > data.budget ? '#e74c3c' : '#2c3e50'};">${totalSpent.toFixed(2)} €</strong></div>
                    </div>

                    <h3 style="font-size: 11px; margin-bottom: 12px; color: #7f8c8d; text-transform: uppercase; letter-spacing:0.5px;">Suivi Budgétaire par Famille (Copie Conforme)</h3>
            `;

            let hasGauges = false;
            CATEGORIES.forEach(cat => {
                const limit = data.categoryBudgets ? (data.categoryBudgets[cat.value] || 0) : 0;
                const spent = categoryTotals[cat.value] || 0;

                if (limit > 0 || spent > 0) {
                    hasGauges = true;
                    let pct = limit > 0 ? (spent / limit) * 100 : 0;
                    let color = pct >= 100 ? "#e74c3c" : (pct >= 70 ? "#f39c12" : "#2ecc71");
                    
                    htmlContent += `
                        <div style="margin-bottom: 12px;">
                            <div style="display: flex; justify-content: space-between; font-size: 11px; font-weight: bold; margin-bottom: 4px;">
                                <span>${cat.label}</span>
                                <span style="color:#555;">${spent.toFixed(2)} € / ${limit > 0 ? limit + ' € (' + pct.toFixed(0) + '%)' : 'Sans limite'}</span>
                            </div>
                            <div style="background: #e9ecef; height: 8px; border-radius: 4px; overflow: hidden;">
                                <div style="background: ${color}; height: 100%; width: ${limit > 0 ? Math.min(pct, 100) : 100}%;"></div>
                            </div>
                        </div>
                    `;
                }
            });

            if (!hasGauges) {
                htmlContent += `<p style="font-size:11px; color:#7f8c8d; text-align:center; padding: 15px; font-style:italic;">Aucune famille budgétisée ni dépense sur ce mois.</p>`;
            }

            htmlContent += `</div>`;
        });

        htmlContent += `</div>`;
        template.innerHTML = htmlContent;

        const opt = {
            margin:       10,
            filename:     `Sauvegarde_Budget_Familles_${new Date().getFullYear()}.pdf`,
            image:        { type: 'jpeg', quality: 0.98 },
            html2canvas:  { scale: 2, useCORS: true },
            jsPDF:        { unit: 'mm', format: 'a4', orientation: 'portrait' }
        };

        // Génération locale et téléchargement transparent
        html2pdf().set(opt).from(template.innerHTML).save().then(() => {
            closePdfModal();
            template.innerHTML = ''; 
        });
    }

    // --- MODE SOMBRE ---
    function toggleDarkMode() {
        const toggle = document.getElementById('dark-mode-toggle');
        const enabled = toggle ? toggle.checked : false;
        document.body.classList.toggle('dark-mode', enabled);
        localStorage.setItem('budget_app_dark_mode', enabled ? 'true' : 'false');
    }

    function loadDarkModePref() {
        const enabled = localStorage.getItem('budget_app_dark_mode') === 'true';
        document.body.classList.toggle('dark-mode', enabled);
        const toggle = document.getElementById('dark-mode-toggle');
        if(toggle) toggle.checked = enabled;
    }

    // --- EXPORT / IMPORT CSV (SAUVEGARDE MANUELLE DES DONNÉES) ---
    function csvEscapeValue(val) {
        val = (val === undefined || val === null) ? '' : String(val);
        if (val.indexOf(';') !== -1 || val.indexOf('"') !== -1 || val.indexOf('\n') !== -1) {
            val = '"' + val.replace(/"/g, '""') + '"';
        }
        return val;
    }

    function exportCSV() {
        const rows = [["type", "mois", "categorie", "libelle", "valeur"]];

        Object.keys(appData).sort().forEach(mId => {
            const data = appData[mId];
            rows.push(["BUDGET", mId, "", "", data.budget || 0]);

            Object.keys(data.categoryBudgets || {}).forEach(cat => {
                rows.push(["CATBUDGET", mId, cat, "", data.categoryBudgets[cat]]);
            });

            (data.items || []).forEach(it => {
                rows.push(["ITEM", mId, it.category, it.name, it.price]);
            });
        });

        const csvContent = rows.map(r => r.map(csvEscapeValue).join(';')).join('\r\n');
        const blob = new Blob(["\uFEFF" + csvContent], { type: 'text/csv;charset=utf-8;' });
        const url = URL.createObjectURL(blob);
        const link = document.createElement('a');
        link.href = url;
        link.download = `Sauvegarde_Budget_${new Date().toISOString().slice(0,10)}.csv`;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
        URL.revokeObjectURL(url);
    }

    function parseCSVLine(line) {
        const result = [];
        let cur = '';
        let inQuotes = false;
        for (let i = 0; i < line.length; i++) {
            const c = line[i];
            if (inQuotes) {
                if (c === '"') {
                    if (line[i + 1] === '"') { cur += '"'; i++; } else { inQuotes = false; }
                } else {
                    cur += c;
                }
            } else {
                if (c === '"') { inQuotes = true; }
                else if (c === ';') { result.push(cur); cur = ''; }
                else { cur += c; }
            }
        }
        result.push(cur);
        return result;
    }

    function importCSV(event) {
        const file = event.target.files && event.target.files[0];
        if (!file) return;

        const reader = new FileReader();
        reader.onload = function(e) {
            try {
                let text = e.target.result;
                if (text.charCodeAt(0) === 0xFEFF) text = text.slice(1);
                const lines = text.split(/\r?\n/).filter(l => l.trim().length > 0);

                if (lines.length < 2) {
                    alert("Fichier CSV vide ou invalide.");
                    event.target.value = '';
                    return;
                }

                const newData = {};
                for (let i = 1; i < lines.length; i++) {
                    const cols = parseCSVLine(lines[i]);
                    const type = cols[0], month = cols[1], category = cols[2], label = cols[3], value = cols[4];
                    if (!month) continue;
                    if (!newData[month]) newData[month] = { budget: 0, items: [], categoryBudgets: {} };

                    if (type === 'BUDGET') {
                        newData[month].budget = parseFloat(value) || 0;
                    } else if (type === 'CATBUDGET') {
                        if (category) newData[month].categoryBudgets[category] = parseFloat(value) || 0;
                    } else if (type === 'ITEM') {
                        newData[month].items.push({
                            name: label || "Dépense",
                            price: parseFloat(value) || 0,
                            category: category || CATEGORIES[0].value
                        });
                    }
                }

                const confirmMsg = "⚠️ Importer ce fichier va REMPLACER toutes les données actuelles de l'application. Continuer ?";
                if (!confirm(confirmMsg)) {
                    event.target.value = '';
                    return;
                }

                appData = newData;
                saveDataLocal();
                renderCategoryBudgetSettings();
                updateUI();
                refreshHistoryCheckboxes();
                updateAnalysis();
                alert("✅ Import réussi !");
            } catch (err) {
                console.error(err);
                alert("❌ Erreur lors de la lecture du fichier CSV.");
            } finally {
                event.target.value = '';
            }
        };
        reader.readAsText(file, 'UTF-8');
    }

    function clearAllData() {
        if(confirm("⚠️ Supprimer définitivement toutes les données de l'appareil ? Cette action est irréversible.")) {
            localStorage.removeItem('budget_app_data_local');
            appData = {};
            location.reload();
        }
    }

    function startApp() {
        document.getElementById('current-month-input').value = selectedMonthId;
        initCategorySelect(); 
        loadDataLocal();
        loadDarkModePref();
        renderCategoryBudgetSettings(); 
        updateUI();
        
        document.getElementById('splash-status').innerText = "Prêt !";
        
        setTimeout(() => {
            const s = document.getElementById('splash-screen');
            if(s) { s.style.opacity = '0'; setTimeout(() => s.style.display = 'none', 500); }
        }, 1300);
    }

    window.addEventListener('DOMContentLoaded', startApp);
</script>
