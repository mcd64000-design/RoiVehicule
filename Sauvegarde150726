/* ============ MAINTENANCE ALERTS ============ */
function computeMaintProgress(v, subKey, intervalKm){
  if(!intervalKm || intervalKm<=0) return null;
  const exp = data.expenses.filter(e=> e.vehicleId===v.id && e.subtypes && e.subtypes.includes(subKey));
  let baseKm = v.kmInitial;
  if(exp.length){
    const last = exp.reduce((max,e)=> e.km>max.km?e:max, exp[0]);
    baseKm = last.km;
  }
  const dueKm = baseKm + intervalKm;
  const remaining = dueKm - v.kmActuel;
  let progress = (v.kmActuel - baseKm) / intervalKm;
  if(progress<0) progress=0;
  if(progress>1) progress=1;
  let status = 'ok';
  if(remaining<=0) status='danger';
  else if(progress>=0.85) status='warn';
  return { baseKm, dueKm, remaining, progress, status };
}
function maintChecksForVehicle(v){
  const checks = [];
  if(v.intervalVidange) checks.push({key:'vidange', label:'Vidange', targetIcon:'💧', interval:v.intervalVidange});
  if(v.intervalPneus) checks.push({key:'pneus', label:'Pneus', targetIcon:'🛞', interval:v.intervalPneus});
  if(v.type==='moto' && v.intervalChaine) checks.push({key:'chaine', label:'Chaîne', targetIcon:'⚙️', interval:v.intervalChaine});
  return checks;
}
function garageAlerts(v){
  const alerts = [];
  maintChecksForVehicle(v).forEach(c=>{
    const p = computeMaintProgress(v, c.key, c.interval);
    if(p && (p.status==='warn' || p.status==='danger')){
      alerts.push(p.status==='danger' ? `⚠️ ${c.label} dépassée` : `⚠️ ${c.label} bientôt`);
    }
  });
  const today = new Date();
  if(v.dateCT){
    const d = new Date(v.dateCT);
    const days = Math.round((d-today)/86400000);
    if(days<=30) alerts.push(days<0 ? '⚠️ CT expiré' : `⚠️ CT dans ${days}j`);
  }
  if(v.dateAssurance){
    const d = new Date(v.dateAssurance);
    const days = Math.round((d-today)/86400000);
    if(days<=30) alerts.push(days<0 ? '⚠️ Assurance expirée' : `⚠️ Assurance dans ${days}j`);
  }
  return alerts;
}
function renderMaintTracker(){
  const v = data.vehicles.find(x=>x.id===currentVehicleId);
  const card = document.getElementById('maint-tracker-card');
  if(!card) return;
  if(!v){ card.innerHTML=''; return; }
  const items = maintChecksForVehicle(v);
  if(items.length===0){
    card.innerHTML = '<div class="empty-state" style="padding:16px 10px;">Renseignez une récurrence (vidange, pneus…) dans les infos du véhicule pour activer le suivi.</div>';
    return;
  }
  const vIcon = vehicleTypeIcon(v.type);
  card.innerHTML = items.map(it=>{
    const p = computeMaintProgress(v, it.key, it.interval);
    const pct = Math.round(p.progress*100);
    const color = p.status==='danger' ? 'var(--danger)' : p.status==='warn' ? '#d97706' : 'var(--kpi)';
    const statusClass = p.status==='danger' ? 'maint-danger' : p.status==='warn' ? 'maint-warn' : 'maint-ok';
    const statusText = p.remaining<=0
      ? `⚠️ Dépassé de ${Math.abs(Math.round(p.remaining)).toLocaleString('fr-FR')} km`
      : `Encore ~${Math.round(p.remaining).toLocaleString('fr-FR')} km`;
    return `
      <div style="margin-bottom:14px;">
        <div class="maint-label"><span>${it.label}</span><span>${pct}%</span></div>
        <div class="maint-track">
          <div class="maint-fill" style="width:${pct}%; background:${color};"></div>
          <div class="maint-icon-moving" style="left:${pct}%;">${vIcon}</div>
          <div class="maint-icon-target">${it.targetIcon}</div>
        </div>
        <div class="maint-status ${statusClass}">${statusText}</div>
      </div>`;
  }).join('');
}

/* ============ BILAN & TENDANCE ============ */
function estimateResaleValue(v){
  if(!v.prixAchat) return null;
  const age = v.anneeMiseEnService ? Math.max(new Date().getFullYear() - v.anneeMiseEnService, 0) : 0;
  let value = v.prixAchat * Math.pow(0.85, age);
  const floor = v.prixAchat * 0.05;
  if(value < floor) value = floor;
  return value;
}
function renderBilan(){
  const v = data.vehicles.find(x=>x.id===currentVehicleId);
  const box = document.getElementById('bilan-box');
  if(!box) return;
  if(!v || !v.prixAchat){
    box.innerHTML = '<div class="empty-state" style="padding:12px 6px;">Renseignez le prix d\'achat du véhicule pour activer le bilan.</div>';
    return;
  }
  const valeurEstimee = estimateResaleValue(v);
  const totalFrais = data.expenses.filter(e=>e.vehicleId===v.id).reduce((s,e)=>s+e.cout,0);
  const coutPossession = v.prixAchat + totalFrais;
  box.innerHTML = `
    <div class="kpi-mini-row">
      <div class="kpi-mini"><div class="v">${fmtMoney(v.prixAchat)}</div><div class="l">Prix d'achat</div></div>
      <div class="kpi-mini"><div class="v">${fmtMoney(valeurEstimee)}</div><div class="l">Valeur estimée</div></div>
    </div>
    <div class="kpi-mini-row">
      <div class="kpi-mini"><div class="v">${fmtMoney(totalFrais)}</div><div class="l">Frais engagés</div></div>
      <div class="kpi-mini"><div class="v">${fmtMoney(coutPossession)}</div><div class="l">Coût de possession</div></div>
    </div>
    <div style="font-size:11px; color:var(--text-secondary); text-align:center; margin-top:6px;">Coût de possession = prix d'achat + frais engagés. Valeur estimée = cote de revente indicative (dépréciation ~15%/an), donnée séparément à titre de repère.</div>`;
}
function renderTrend(){
  const v = data.vehicles.find(x=>x.id===currentVehicleId);
  const box = document.getElementById('trend-box');
  if(!box) return;
  if(!v){ box.innerHTML=''; return; }
  const exp = data.expenses.filter(e=>e.vehicleId===v.id).sort((a,b)=>a.date.localeCompare(b.date));
  if(exp.length < 4){
    box.innerHTML = '<div class="empty-state" style="padding:12px 6px;">Pas encore assez de données pour dégager une tendance.</div>';
    return;
  }
  const dates = exp.map(e=>e.date);
  const firstDate = new Date(dates[0]);
  const lastDate = new Date(dates[dates.length-1]);
  const midTime = (firstDate.getTime()+lastDate.getTime())/2;
  const midStr = new Date(midTime).toISOString().slice(0,10);
  const firstHalf = exp.filter(e=>e.date<midStr);
  const secondHalf = exp.filter(e=>e.date>=midStr);
  const totalFirst = firstHalf.reduce((s,e)=>s+e.cout,0);
  const totalSecond = secondHalf.reduce((s,e)=>s+e.cout,0);
  if(totalFirst<=0){ box.innerHTML = '<div class="empty-state" style="padding:12px 6px;">Pas encore assez de données pour dégager une tendance.</div>'; return; }
  const variation = ((totalSecond-totalFirst)/totalFirst)*100;
  let icon, text, cls;
  if(variation > 20){ icon='📈'; cls='maint-danger'; text='Coût en forte hausse ('+Math.round(variation)+'%)'; }
  else if(variation > 5){ icon='📈'; cls='maint-warn'; text='Coût en légère hausse ('+Math.round(variation)+'%)'; }
  else if(variation < -5){ icon='📉'; cls='maint-ok'; text='Coût en baisse ('+Math.round(variation)+'%)'; }
  else { icon='➡️'; cls='maint-ok'; text='Coût stable'; }
  box.innerHTML = `<div style="font-size:26px; text-align:center; margin-bottom:4px;">${icon}</div>
    <div class="maint-status ${cls}" style="text-align:center; font-size:13px;">${text}</div>
    <div style="text-align:center; font-size:11px; color:var(--text-secondary); margin-top:4px;">Comparaison 1ère vs 2ème moitié de l'historique</div>`;
}

function renderGarage(){
  const list = document.getElementById('garage-list');
  if(data.vehicles.length === 0){
    list.innerHTML = '<div class="empty-state">Aucun véhicule pour le moment.<br>Ajoutez votre premier véhicule ci-dessous 👇</div>';
    return;
  }
  const currentYear = new Date().getFullYear();
  const sorted = [...data.vehicles].sort((a,b)=> (b.favori?1:0)-(a.favori?1:0));
  list.innerHTML = sorted.map(v=>{
    const exp = data.expenses.filter(e=>e.vehicleId===v.id);
    const total = exp.reduce((s,e)=>s+e.cout,0);
    const kmParcourus = Math.max(v.kmActuel - v.kmInitial, 0);
    const coutKm = kmParcourus > 0 ? total/kmParcourus : 0;
    const age = v.anneeMiseEnService ? Math.max(currentYear - v.anneeMiseEnService, 0) : null;
    const ageLabel = age !== null ? (age <= 1 ? age+' an' : age+' ans') : null;
    const alerts = garageAlerts(v).slice(0,2);
    return `
      <div class="card vehicule-card" onclick="openVehicule('${v.id}')">
        <div class="fav-icon" onclick="event.stopPropagation(); toggleFavori('${v.id}')">${v.favori ? '⭐' : '☆'}</div>
        <div class="edit-icon" onclick="event.stopPropagation(); openEditVehicule('${v.id}')">⋯</div>
        <div class="del-icon" onclick="event.stopPropagation(); askDeleteVehicule('${v.id}')">🗑️</div>
        <h3>${vehicleTypeIcon(v.type)} ${escapeHtml(v.marque)} ${escapeHtml(v.modele)}</h3>
        <span class="plate">${escapeHtml(v.immat)}</span>
        ${ageLabel ? `<span class="age-badge">${ageLabel}</span>` : ''}
        ${v.prixAchat ? `<span class="age-badge">Achat : ${fmtMoney(v.prixAchat)}</span>` : ''}
        ${alerts.map(a=>`<span class="warn-badge">${a}</span>`).join('')}
        <div class="vehicule-stats">
          <div class="stat-box"><div class="val">${v.kmActuel.toLocaleString('fr-FR')} km</div><div class="lbl">Kilométrage</div></div>
          <div class="stat-box"><div class="val">${fmtMoney(total)}</div><div class="lbl">Coût total</div></div>
          <div class="stat-box"><div class="val">${fmtMoney(coutKm)}</div><div class="lbl">€/km</div></div>
        </div>
      </div>`;
  }).join('');
}

