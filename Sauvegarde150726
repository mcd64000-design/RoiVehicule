/* ============ CSV EXPORT / IMPORT ============ */
function csvEscape(val){
  if(val === null || val === undefined) return '';
  const str = String(val);
  if(/[",\n;]/.test(str)){
    return '"' + str.replace(/"/g,'""') + '"';
  }
  return str;
}
function downloadCSV(content, filename){
  const bom = '\uFEFF';
  const blob = new Blob([bom+content], {type:'text/csv;charset=utf-8;'});
  const url = URL.createObjectURL(blob);
  if(navigator.share && /iPhone|iPad|iPod/.test(navigator.userAgent)){
    try{
      const file = new File([blob], filename, {type:'text/csv'});
      if(navigator.canShare && navigator.canShare({files:[file]})){
        navigator.share({files:[file], title: filename}).catch(()=>{ fallbackDownloadCSV(url, filename); });
        return;
      }
    }catch(e){}
  }
  fallbackDownloadCSV(url, filename);
}
function fallbackDownloadCSV(url, filename){
  const a = document.createElement('a');
  a.href = url;
  a.download = filename;
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  setTimeout(()=>URL.revokeObjectURL(url), 3000);
}
function exportVehicleCSV(){
  const v = data.vehicles.find(x=>x.id===currentVehicleId);
  if(!v) return;
  const rows = [];
  rows.push(['TYPE','marque','modele','immat','anneeMiseEnService','prixAchat','vtype','favori','kmInitial','kmActuel','intervalVidange','intervalPneus','intervalChaine','dateCT','dateAssurance'].map(csvEscape).join(','));
  rows.push(['VEHICULE', v.marque, v.modele, v.immat, v.anneeMiseEnService||'', v.prixAchat||'', v.type||'', v.favori?1:0, v.kmInitial, v.kmActuel, v.intervalVidange||'', v.intervalPneus||'', v.intervalChaine||'', v.dateCT||'', v.dateAssurance||''].map(csvEscape).join(','));
  rows.push('');
  rows.push(['TYPE','date','depenseType','subtypes','autreLabel','cout','km','comment'].map(csvEscape).join(','));
  const exp = data.expenses.filter(e=>e.vehicleId===v.id).sort((a,b)=>a.date.localeCompare(b.date));
  exp.forEach(e=>{
    const subtypes = (e.subtypes||[]).join('|');
    rows.push(['DEPENSE', e.date, e.type, subtypes, e.autreLabel||'', e.cout, e.km, e.comment||''].map(csvEscape).join(','));
  });
  const csvContent = rows.join('\r\n');
  downloadCSV(csvContent, 'sauvegarde_'+v.immat.replace(/\s/g,'')+'_'+todayStr()+'.csv');
}
function parseCSVLine(line){
  const result = [];
  let cur = '';
  let inQuotes = false;
  for(let i=0;i<line.length;i++){
    const c = line[i];
    if(inQuotes){
      if(c==='"'){
        if(line[i+1]==='"'){ cur+='"'; i++; }
        else { inQuotes=false; }
      } else {
        cur += c;
      }
    } else {
      if(c==='"'){ inQuotes=true; }
      else if(c===','){ result.push(cur); cur=''; }
      else { cur += c; }
    }
  }
  result.push(cur);
  return result;
}
function triggerImportCSV(){
  document.getElementById('csv-file-input').click();
}
function handleCSVFileSelect(evt){
  const file = evt.target.files[0];
  if(file) importCSVFile(file);
  evt.target.value = '';
}
function importCSVFile(file){
  const reader = new FileReader();
  reader.onload = function(evt){
    try{
      let text = evt.target.result;
      if(text.charCodeAt(0) === 0xFEFF) text = text.slice(1);
      const lines = text.split(/\r\n|\n/).filter(l=>l.length>0);
      let vehicleRow = null;
      const expenseRows = [];
      lines.forEach(line=>{
        const cols = parseCSVLine(line);
        if(cols[0]==='VEHICULE'){ vehicleRow = cols; }
        else if(cols[0]==='DEPENSE'){ expenseRows.push(cols); }
      });
      if(!vehicleRow){
        alert('Fichier CSV invalide ou non reconnu.');
        return;
      }
      const marque = vehicleRow[1], modele = vehicleRow[2], immat = vehicleRow[3];
      const anneeStr = vehicleRow[4], prixStr = vehicleRow[5], vtype = vehicleRow[6];
      const kmInitialStr = vehicleRow[8], kmActuelStr = vehicleRow[9];
      const intVidangeStr = vehicleRow[10], intPneusStr = vehicleRow[11], intChaineStr = vehicleRow[12];
      const dateCT = vehicleRow[13], dateAssurance = vehicleRow[14];

      const newVehicleId = uid();
      const v = {
        id: newVehicleId,
        marque: marque || 'Véhicule',
        modele: modele || 'importé',
        immat: immat || '',
        anneeMiseEnService: anneeStr ? parseInt(anneeStr,10) : null,
        prixAchat: prixStr ? parseNum(prixStr) : null,
        type: vtype || 'voiture',
        favori: false,
        kmInitial: kmInitialStr ? parseNum(kmInitialStr) : 0,
        kmActuel: kmActuelStr ? parseNum(kmActuelStr) : 0,
        intervalVidange: intVidangeStr ? parseNum(intVidangeStr) : null,
        intervalPneus: intPneusStr ? parseNum(intPneusStr) : null,
        intervalChaine: intChaineStr ? parseNum(intChaineStr) : null,
        dateCT: dateCT || null,
        dateAssurance: dateAssurance || null,
        createdAt: todayStr()
      };
      data.vehicles.push(v);
      data.kmLogs.push({ id: uid(), vehicleId: v.id, date: todayStr(), km: v.kmActuel });

      expenseRows.forEach(cols=>{
        const date = cols[1], depenseType = cols[2], subtypesStr = cols[3], autreLabel = cols[4];
        const coutStr = cols[5], kmStr = cols[6], comment = cols[7];
        const e = {
          id: uid(),
          vehicleId: v.id,
          type: depenseType || 'carburant',
          subtypes: subtypesStr ? subtypesStr.split('|').filter(Boolean) : [],
          autreLabel: autreLabel || null,
          date: date || todayStr(),
          cout: coutStr ? parseNum(coutStr) : 0,
          km: kmStr ? parseNum(kmStr) : v.kmInitial,
          comment: comment || ''
        };
        data.expenses.push(e);
      });

      saveData();
      renderGarage();
      alert('Véhicule importé avec succès : '+v.marque+' '+v.modele);
      openScreen('garage');
    } catch(err){
      alert('Erreur lors de la lecture du fichier CSV.');
    }
  };
  reader.readAsText(file, 'UTF-8');
}

function updateSettingsUI(){
  document.getElementById('opt-light').classList.toggle('active-opt', data.theme==='light');
  document.getElementById('opt-dark').classList.toggle('active-opt', data.theme==='dark');
  document.getElementById('opt-eur').classList.toggle('active-opt', data.currency==='EUR');
  document.getElementById('opt-usd').classList.toggle('active-opt', data.currency==='USD');
  document.getElementById('input-username').value = data.username || '';
}
function saveUsername(){
  data.username = document.getElementById('input-username').value;
  saveData();
}
function setTheme(t){
  data.theme = t;
  document.documentElement.setAttribute('data-theme', t);
  saveData();
  updateSettingsUI();
}
function setCurrency(c){
  data.currency = c;
  saveData();
  updateSettingsUI();
  renderGarage();
  if(currentVehicleId){ refreshVehStats(); renderSuiviRecent(); }
}

function escapeHtml(str){
  return (str||'').replace(/[&<>"']/g, m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]));
}

init();
</script>
</body>
</html>
