function createVehicule(){
  const marque = document.getElementById('v-marque').value.trim();
  const modele = document.getElementById('v-modele').value.trim();
  const immat = document.getElementById('v-immat').value.trim();
  const anneeStr = document.getElementById('v-annee').value.trim();
  const prixStr = document.getElementById('v-prix').value.trim();
  const km = parseNum(document.getElementById('v-km').value);
  const anneeMiseEnService = parseInt(anneeStr, 10);
  const currentYear = new Date().getFullYear();
  if(!marque || !modele || !immat || isNaN(km)){
    alert('Merci de remplir tous les champs obligatoires.');
    return;
  }
  if(!anneeStr || isNaN(anneeMiseEnService) || anneeMiseEnService < 1950 || anneeMiseEnService > currentYear){
    alert('Merci de saisir une année de mise en service valide (ex : 2018).');
    return;
  }
  if(!selectedVType){
    alert('Merci de choisir le type de véhicule.');
    return;
  }
  let prixAchat = null;
  if(prixStr){
    prixAchat = parseNum(prixStr);
    if(isNaN(prixAchat)){
      alert("Le prix d'achat saisi est invalide.");
      return;
    }
  }
  const intVidangeStr = document.getElementById('v-int-vidange').value.trim();
  const intPneusStr = document.getElementById('v-int-pneus').value.trim();
  const intChaineStr = document.getElementById('v-int-chaine').value.trim();
  const dateCT = document.getElementById('v-date-ct').value || null;
  const dateAssurance = document.getElementById('v-date-assurance').value || null;
  const intervalVidange = intVidangeStr ? parseNum(intVidangeStr) : null;
  const intervalPneus = intPneusStr ? parseNum(intPneusStr) : null;
  const intervalChaine = intChaineStr ? parseNum(intChaineStr) : null;

  const v = { id: uid(), marque, modele, immat, anneeMiseEnService, prixAchat, type: selectedVType, favori:false,
    intervalVidange: (intervalVidange!=null && !isNaN(intervalVidange)) ? intervalVidange : null,
    intervalPneus: (intervalPneus!=null && !isNaN(intervalPneus)) ? intervalPneus : null,
    intervalChaine: (intervalChaine!=null && !isNaN(intervalChaine)) ? intervalChaine : null,
    dateCT, dateAssurance,
    kmInitial: km, kmActuel: km, createdAt: todayStr() };
  data.vehicles.push(v);
  data.kmLogs.push({ id: uid(), vehicleId: v.id, date: todayStr(), km });
  saveData();
  closeModal('modal-vehicule');
  renderGarage();
}

function askDeleteVehicule(id){
  openConfirm('Cette action est irréversible. Voulez-vous continuer ?', ()=>{
    data.vehicles = data.vehicles.filter(v=>v.id!==id);
    data.expenses = data.expenses.filter(e=>e.vehicleId!==id);
    data.kmLogs = data.kmLogs.filter(k=>k.vehicleId!==id);
    saveData();
    renderGarage();
  });
}

function toggleFavori(id){
  const v = data.vehicles.find(x=>x.id===id);
  if(!v) return;
  const wasFavori = v.favori;
  data.vehicles.forEach(x=>x.favori=false);
  v.favori = !wasFavori;
  saveData();
  renderGarage();
}

function openEditVehicule(id){
  const v = data.vehicles.find(x=>x.id===id);
  if(!v) return;
  editingVehicleId = id;
  document.getElementById('e-marque').value = v.marque;
  document.getElementById('e-modele').value = v.modele;
  document.getElementById('e-immat').value = v.immat;
  document.getElementById('e-annee').value = v.anneeMiseEnService || '';
  document.getElementById('e-prix').value = v.prixAchat != null ? v.prixAchat : '';
  document.getElementById('e-int-vidange').value = v.intervalVidange || '';
  document.getElementById('e-int-pneus').value = v.intervalPneus || '';
  document.getElementById('e-int-chaine').value = v.intervalChaine || '';
  document.getElementById('e-date-ct').value = v.dateCT || '';
  document.getElementById('e-date-assurance').value = v.dateAssurance || '';
  selectedEVType = v.type || null;
  document.querySelectorAll('#edit-type-grid .choice-btn').forEach(b=>b.classList.toggle('selected', b.dataset.evtype===selectedEVType));
  document.getElementById('e-chaine-zone').style.display = (selectedEVType==='moto') ? 'block' : 'none';
  openModal('modal-edit-vehicule');
}
function selectEVType(t){
  selectedEVType = t;
  document.querySelectorAll('#edit-type-grid .choice-btn').forEach(b=>b.classList.toggle('selected', b.dataset.evtype===t));
  document.getElementById('e-chaine-zone').style.display = t==='moto' ? 'block' : 'none';
}
function saveEditVehicule(){
  const v = data.vehicles.find(x=>x.id===editingVehicleId);
  if(!v) return;
  const marque = document.getElementById('e-marque').value.trim();
  const modele = document.getElementById('e-modele').value.trim();
  const immat = document.getElementById('e-immat').value.trim();
  const anneeStr = document.getElementById('e-annee').value.trim();
