function histoItemHtml(e, withDelete){
  const subtypes = e.subtypes || (e.subtype ? [e.subtype] : []);
  let label;
  if(e.type==='carburant'){
    label = '⛽ Carburant';
  } else {
    const parts = subtypes.map(s => s==='autre' ? ('Autre'+(e.autreLabel ? ' ('+e.autreLabel+')' : '')) : subLabel(s));
    label = '🔧 '+parts.join(', ');
  }
  const tagClass = e.type==='carburant' ? 'tag-carburant' : 'tag-entretien';
  return `
    <div class="histo-item">
      <div class="histo-left">
        <span class="type-tag ${tagClass}">${label}</span>
        <div class="date">${formatDate(e.date)}</div>
        ${e.comment ? `<div class="comment">"${escapeHtml(e.comment)}"</div>` : ''}
      </div>
      <div class="histo-right">
        <div class="amount">${fmtMoney(e.cout)}</div>
        <div class="km">${e.km.toLocaleString('fr-FR')} km</div>
      </div>
      ${withDelete ? `<div class="histo-del" onclick="askDeleteDepense('${e.id}')">🗑️</div>` : ''}
    </div>`;
}
function subLabel(s){
  return {pneus:'Pneus', vidange:'Vidange', plaquettes:'Plaquettes', disques:'Disques de frein', autre:'Autre', chaine:'Chaîne'}[s] || 'Entretien';
}
function formatDate(d){
  const [y,m,day] = d.split('-');
  return day+'/'+m+'/'+y;
}
