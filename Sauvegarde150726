function uid(){ return Date.now().toString(36)+Math.random().toString(36).slice(2,8); }
function parseNum(str){
  if(!str) return NaN;
  return parseFloat(str.toString().replace(',','.').trim());
}
function todayStr(){ return new Date().toISOString().slice(0,10); }
function fmtMoney(v){
  const sym = data.currency === 'USD' ? '$' : '€';
  return (Math.round(v*100)/100).toLocaleString('fr-FR') + ' ' + sym;
}
function vehicleTypeIcon(t){
  return {voiture:'🚘', camion:'🚚', scooter:'🛵', moto:'🏍️', tracteur:'🚜'}[t] || '🚘';
}
function vehicleTypeLabel(t){
