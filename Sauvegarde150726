<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Mon Budget Voiture</title>
<style>
:root{
  --bg:#f2f3f7;
  --card-bg:#ffffff;
  --text:#1a1a2e;
  --text-secondary:#6b7280;
  --border:#e5e7eb;
  --garage:#2563eb;
  --garage-bg:#eaf1fe;
  --depense:#ff6b35;
  --depense-bg:#fff1ea;
  --kpi:#16a34a;
  --kpi-bg:#eafbf0;
  --reglages:#6c757d;
  --reglages-bg:#eef0f2;
  --danger:#e11d48;
  --shadow:0 2px 10px rgba(0,0,0,0.06);
}
[data-theme="dark"]{
  --bg:#121218;
  --card-bg:#1c1c26;
  --text:#f2f3f7;
  --text-secondary:#9ca3af;
  --border:#2d2d3a;
  --garage-bg:#17233d;
  --depense-bg:#3a2417;
  --kpi-bg:#123a22;
  --reglages-bg:#26262f;
  --shadow:0 2px 10px rgba(0,0,0,0.4);
}
*{box-sizing:border-box; -webkit-tap-highlight-color:transparent;}
body{
  margin:0; font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;
  background:var(--bg); color:var(--text); min-height:100vh; padding-bottom:20px;
  transition:background .2s,color .2s;
}
.container{max-width:480px; margin:0 auto; padding:16px;}
.screen{display:none;}
.screen.active{display:block; animation:fadeIn .2s ease;}
@keyframes fadeIn{from{opacity:0; transform:translateY(6px);} to{opacity:1; transform:translateY(0);}}

#splash-screen{
  position:fixed; inset:0; z-index:999;
  background:linear-gradient(135deg,#2563eb,#16a34a);
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  animation: splashFadeOut .6s ease 3.2s forwards;
}
.splash-logo{font-size:64px; animation: splashPop .8s ease;}
.splash-title{color:#fff; font-size:20px; font-weight:800; margin-top:14px; opacity:0; animation: splashTextIn .6s ease .5s forwards; letter-spacing:.5px;}
.splash-brand{color:rgba(255,255,255,0.85); font-size:12px; font-weight:700; letter-spacing:1.5px; margin-top:10px; opacity:0; animation: splashTextIn .6s ease .9s forwards; text-transform:uppercase;}
@keyframes splashPop{0%{transform:scale(0.4);opacity:0;} 60%{transform:scale(1.15);opacity:1;} 100%{transform:scale(1);opacity:1;}}
@keyframes splashTextIn{from{opacity:0; transform:translateY(8px);} to{opacity:1; transform:translateY(0);}}
@keyframes splashFadeOut{to{opacity:0; visibility:hidden;}}

.topbar{display:flex; align-items:center; justify-content:space-between; margin-bottom:16px;}
.topbar h1{font-size:20px; margin:0; font-weight:700;}
.icon-btn{
  background:var(--card-bg); border:1px solid var(--border); width:42px; height:42px;
  border-radius:14px; display:flex; align-items:center; justify-content:center;
  font-size:18px; cursor:pointer; box-shadow:var(--shadow); color:var(--text);
}
.back-btn{display:flex; align-items:center; gap:6px; color:var(--text-secondary); font-size:14px; cursor:pointer; margin-bottom:8px;}

.btn{
  border:none; border-radius:16px; padding:14px 18px; font-size:15px; font-weight:600;
  cursor:pointer; width:100%; display:flex; align-items:center; justify-content:center; gap:8px;
  box-shadow:var(--shadow);
}
.btn-garage{background:var(--garage); color:#fff;}
.btn-depense{background:var(--depense); color:#fff;}
.btn-kpi{background:var(--kpi); color:#fff;}
.btn-outline{background:var(--card-bg); color:var(--text); border:1px solid var(--border);}
.btn-danger{background:var(--danger); color:#fff;}
.btn-sm{padding:10px 14px; font-size:13px; border-radius:12px;}
.btn-row{display:flex; gap:10px; margin-top:10px;}

.card{
  background:var(--card-bg); border-radius:18px; padding:16px; box-shadow:var(--shadow);
  margin-bottom:12px; border:1px solid var(--border);
}
.vehicule-card{cursor:pointer; position:relative;}
.vehicule-card h3{margin:0 0 2px; font-size:17px; padding-right:80px;}
.vehicule-card .plate{
  display:inline-block; background:var(--garage-bg); color:var(--garage); font-weight:700;
  font-size:12px; padding:3px 8px; border-radius:8px; margin-top:4px;
}
.age-badge{
  display:inline-block; background:var(--reglages-bg); color:var(--reglages); font-weight:700;
  font-size:12px; padding:3px 8px; border-radius:8px; margin-top:4px; margin-left:6px;
}
.warn-badge{
  display:inline-block; background:#fef3c7; color:#b45309; font-weight:700;
  font-size:11px; padding:3px 8px; border-radius:8px; margin-top:4px; margin-left:6px;
}
[data-theme="dark"] .warn-badge{background:#3a2b0f; color:#fbbf24;}
.vehicule-stats{display:flex; gap:10px; margin-top:12px;}
.stat-box{flex:1; background:var(--bg); border-radius:12px; padding:10px; text-align:center;}
.stat-box .val{font-size:16px; font-weight:700;}
.stat-box .lbl{font-size:11px; color:var(--text-secondary); margin-top:2px;}
.fav-icon{position:absolute; top:14px; right:76px; font-size:17px; cursor:pointer;}
.edit-icon{position:absolute; top:14px; right:44px; font-size:19px; opacity:.6; cursor:pointer; font-weight:900; line-height:1;}
.del-icon{position:absolute; top:14px; right:14px; font-size:16px; opacity:.5; cursor:pointer;}

.empty-state{text-align:center; color:var(--text-secondary); padding:40px 10px; font-size:14px;}

.km-hero{
  background:linear-gradient(135deg,var(--garage),#4f8ff7); color:#fff; border-radius:20px;
  padding:22px; text-align:center; margin-bottom:14px; box-shadow:var(--shadow);
}
.km-hero .big{font-size:34px; font-weight:800;}
.km-hero .sub{font-size:13px; opacity:.9; margin-top:2px;}
.kpi-mini-row{display:flex; gap:10px; margin-bottom:14px;}
.kpi-mini{flex:1; background:var(--card-bg); border-radius:14px; padding:12px; text-align:center; border:1px solid var(--border);}
.kpi-mini .v{font-size:16px; font-weight:700;}
.kpi-mini .l{font-size:11px; color:var(--text-secondary);}

.tabbar{display:flex; gap:8px; margin:16px 0;}
.tab-btn{
  flex:1; text-align:center; padding:10px 4px; border-radius:12px; font-size:12px; font-weight:600;
  cursor:pointer; border:1px solid var(--border); background:var(--card-bg); color:var(--text-secondary);
}
.tab-btn.active-tab{color:#fff; border:none;}
.tab-btn[data-tab="suivi"].active-tab{background:var(--depense);}
.tab-btn[data-tab="historique"].active-tab{background:var(--garage);}
.tab-btn[data-tab="kpi"].active-tab{background:var(--kpi);}

.subview{display:none;}
.subview.active{display:block;}

.histo-item{
  display:flex; justify-content:space-between; align-items:center; padding:12px; border-radius:14px;
  background:var(--card-bg); border:1px solid var(--border); margin-bottom:8px;
}
.histo-left .type-tag{
  font-size:11px; font-weight:700; padding:2px 8px; border-radius:8px; display:inline-block; margin-bottom:4px;
}
.tag-carburant{background:var(--depense-bg); color:var(--depense);}
.tag-entretien{background:var(--kpi-bg); color:var(--kpi);}
.histo-left .date{font-size:12px; color:var(--text-secondary);}
.histo-left .comment{font-size:12px; color:var(--text-secondary); font-style:italic; margin-top:2px;}
.histo-right{text-align:right;}
.histo-right .amount{font-weight:700; font-size:15px;}
.histo-right .km{font-size:11px; color:var(--text-secondary);}
.histo-del{font-size:15px; opacity:.4; margin-left:10px; cursor:pointer;}

.date-range{display:flex; gap:8px; margin-bottom:12px;}
.date-range input{flex:1;}
.timeline-block{margin-bottom:10px;}
.timeline-title{font-size:13px; font-weight:700; margin-bottom:6px; display:flex; align-items:center; gap:6px;}
.timeline-entry{
  font-size:12px; color:var(--text-secondary); padding:8px 10px; background:var(--bg);
  border-radius:10px; margin-bottom:5px; display:flex; justify-content:space-between;
}

label{font-size:12px; font-weight:600; color:var(--text-secondary); display:block; margin:10px 0 4px;}
input[type="text"], input[type="date"], select, textarea{
  width:100%; padding:12px; border-radius:12px; border:1px solid var(--border);
  background:var(--bg); color:var(--text); font-size:15px; font-family:inherit;
}
textarea{resize:none; height:60px;}

.type-choice{display:flex; gap:8px; margin-top:4px;}
.choice-btn{
  flex:1; padding:12px 6px; border-radius:12px; border:1px solid var(--border); background:var(--bg);
  text-align:center; font-size:13px; font-weight:600; cursor:pointer; color:var(--text-secondary);
}
.choice-btn.selected{color:#fff; border:none;}
.choice-btn.selected[data-val="carburant"]{background:var(--depense);}
.choice-btn.selected[data-val="entretien"]{background:var(--kpi);}
.choice-btn.selected[data-sub]{background:var(--garage);}
.choice-btn.selected[data-vtype]{background:var(--garage);}
.choice-btn.selected[data-evtype]{background:var(--garage);}
.choice-btn.selected[data-exp="carburant"]{background:var(--depense);}
.choice-btn.selected[data-exp="entretien"]{background:var(--kpi);}

.sub-grid{display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-top:4px;}

.maint-label{display:flex; justify-content:space-between; font-size:11px; color:var(--text-secondary); margin-bottom:4px;}
.maint-track{position:relative; height:34px; background:var(--bg); border-radius:17px; border:1px solid var(--border); overflow:hidden;}
.maint-fill{position:absolute; top:0; left:0; height:100%; border-radius:17px; transition:width .3s;}
.maint-icon-moving{position:absolute; top:50%; transform:translate(-50%,-50%); font-size:18px; transition:left .3s;}
.maint-icon-target{position:absolute; top:50%; right:8px; transform:translateY(-50%); font-size:16px; opacity:.7;}
.maint-status{font-size:11px; font-weight:700; margin-top:4px;}
.maint-ok{color:var(--kpi);}
.maint-warn{color:#d97706;}
.maint-danger{color:var(--danger);}

.modal-overlay{
  display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:100;
  align-items:flex-end; justify-content:center;
}
.modal-overlay.active{display:flex;}
.modal-box{
  background:var(--card-bg); width:100%; max-width:480px; border-radius:22px 22px 0 0;
  padding:20px; max-height:88vh; overflow-y:auto; animation:slideUp .25s ease;
}
@keyframes slideUp{from{transform:translateY(30px); opacity:0;} to{transform:translateY(0); opacity:1;}}
.modal-header{display:flex; justify-content:space-between; align-items:center; margin-bottom:6px;}
.modal-header h2{font-size:18px; margin:0;}
.close-x{font-size:20px; cursor:pointer; color:var(--text-secondary);}

.confirm-box p{font-size:14px; color:var(--text-secondary);}

.settings-row{
  display:flex; justify-content:space-between; align-items:center; padding:14px 0; border-bottom:1px solid var(--border);
}
.settings-row:last-child{border-bottom:none;}
.settings-row .lbl{font-size:14px; font-weight:600;}
.switch{display:flex; gap:6px;}
.switch-opt{
  padding:8px 14px; border-radius:10px; font-size:12px; font-weight:700; cursor:pointer;
  border:1px solid var(--border); color:var(--text-secondary);
}
.switch-opt.active-opt{background:var(--reglages); color:#fff; border:none;}
</style>
</head>
<body>

<div id="splash-screen">
  <div class="splash-logo">🚗</div>
  <div class="splash-title">Mon Budget Voiture</div>
  <div class="splash-brand">By MCD STUDIO</div>
</div>

<div class="container">

  <div class="screen active" id="screen-garage">
    <div class="topbar">
      <h1>🚗 Mon Garage</h1>
      <div class="icon-btn" onclick="openScreen('reglages')">⚙️</div>
    </div>
    <div id="garage-list"></div>
    <button class="btn btn-garage" onclick="openAddVehiculeModal()">➕ Ajouter un véhicule</button>
  </div>

  <div class="screen" id="screen-vehicule">
    <div class="back-btn" onclick="openScreen('garage')">⬅ Retour au garage</div>
    <div class="topbar">
      <h1 id="veh-title">Véhicule</h1>
    </div>
    <div class="km-hero">
      <div class="big" id="veh-km">0 km</div>
      <div class="sub" id="veh-plate">—</div>
    </div>
    <div class="kpi-mini-row">
      <div class="kpi-mini"><div class="v" id="veh-cout-total">0 €</div><div class="l">Coût total</div></div>
      <div class="kpi-mini"><div class="v" id="veh-cout-km">0 €</div><div class="l">€ / km</div></div>
    </div>

    <div class="tabbar">
      <div class="tab-btn active-tab" data-tab="suivi" onclick="switchTab('suivi')">➕ Suivi</div>
      <div class="tab-btn" data-tab="historique" onclick="switchTab('historique')">📜 Historique</div>
      <div class="tab-btn" data-tab="kpi" onclick="switchTab('kpi')">📊 KPI</div>
    </div>

    <div class="subview active" id="tab-suivi">
      <button class="btn btn-depense" onclick="openModalDepense()">➕ Ajouter une dépense</button>
      <div class="btn-row">
        <button class="btn btn-outline" onclick="openPleinExpress()">⚡ Plein express</button>
        <button class="btn btn-outline" onclick="openModal('modal-km')">📍 Mettre à jour le KM</button>
      </div>
      <div class="card" style="margin-top:14px;">
        <div style="font-size:13px; font-weight:700; margin-bottom:6px;">🔔 Entretiens à venir</div>
        <div id="maint-tracker-card"></div>
      </div>
      <div class="card">
        <div style="font-size:13px; color:var(--text-secondary);">Dernières opérations</div>
        <div id="suivi-recent" style="margin-top:10px;"></div>
      </div>
    </div>

    <div class="subview" id="tab-historique">
      <div id="historique-list"></div>
    </div>

    <div class="subview" id="tab-kpi">
      <div class="date-range">
        <input type="date" id="kpi-start">
        <input type="date" id="kpi-end">
      </div>
      <button class="btn btn-kpi btn-sm" onclick="renderKPI()">Appliquer le filtre</button>
      <button class="btn btn-outline btn-sm" style="margin-top:8px;" onclick="openExportModal()">📄 Exporter en PDF</button>
      <div class="btn-row">
        <button class="btn btn-outline btn-sm" onclick="exportVehicleCSV()">📤 Exporter CSV</button>
        <button class="btn btn-outline btn-sm" onclick="triggerImportCSV()">📥 Importer CSV</button>
      </div>
      <input type="file" id="csv-file-input" accept=".csv" style="display:none;" onchange="handleCSVFileSelect(event)">

      <div class="kpi-mini-row" style="margin-top:14px;">
        <div class="kpi-mini"><div class="v" id="kpi-cout-total">0 €</div><div class="l">Coût période</div></div>
        <div class="kpi-mini"><div class="v" id="kpi-cout-km">0 €</div><div class="l">€ / km période</div></div>
      </div>

      <div class="card">
        <div style="font-weight:700; font-size:14px; margin-bottom:10px;">💰 Bilan véhicule</div>
        <div id="bilan-box"></div>
      </div>

      <div class="card">
        <div style="font-weight:700; font-size:14px; margin-bottom:6px;">📊 Tendance du coût</div>
        <div id="trend-box"></div>
      </div>

      <div class="card">
        <div style="font-weight:700; font-size:14px; margin-bottom:10px;">🔧 Récurrence entretien</div>
        <div id="kpi-timelines"></div>
      </div>
    </div>
  </div>

  <div class="screen" id="screen-reglages">
    <div class="back-btn" onclick="openScreen('garage')">⬅ Retour au garage</div>
    <div class="topbar"><h1>⚙️ Réglages</h1></div>
    <div class="card">
      <label>Nom d'utilisateur</label>
      <input type="text" id="input-username" placeholder="Votre nom" oninput="saveUsername()">
    </div>
    <div class="card">
      <div class="settings-row">
        <div class="lbl">Apparence</div>
        <div class="switch">
          <div class="switch-opt" id="opt-light" onclick="setTheme('light')">☀️ Clair</div>
          <div class="switch-opt" id="opt-dark" onclick="setTheme('dark')">🌙 Sombre</div>
        </div>
      </div>
      <div class="settings-row">
        <div class="lbl">Devise</div>
        <div class="switch">
          <div class="switch-opt" id="opt-eur" onclick="setCurrency('EUR')">€ EUR</div>
          <div class="switch-opt" id="opt-usd" onclick="setCurrency('USD')">$ USD</div>
        </div>
      </div>
    </div>
  </div>

</div>

<div class="modal-overlay" id="modal-vehicule">
  <div class="modal-box">
    <div class="modal-header"><h2>Nouveau véhicule</h2><div class="close-x" onclick="closeModal('modal-vehicule')">✕</div></div>
    <label>Marque</label>
    <input type="text" id="v-marque" placeholder="Peugeot">
    <label>Modèle</label>
    <input type="text" id="v-modele" placeholder="308">
    <label>Immatriculation</label>
    <input type="text" id="v-immat" placeholder="AA-123-BB">
    <label>Année de mise en service</label>
    <input type="text" inputmode="numeric" id="v-annee" placeholder="Ex : 2018">
    <label>Prix d'achat (optionnel)</label>
    <input type="text" inputmode="decimal" id="v-prix" placeholder="Ex : 18500">
    <label>Kilométrage actuel</label>
    <input type="text" inputmode="decimal" id="v-km" placeholder="Ex : 45000">
    <label>Type de véhicule</label>
    <div class="sub-grid" id="type-grid">
      <div class="choice-btn" data-vtype="voiture" onclick="selectVType('voiture')">🚘 Voiture</div>
      <div class="choice-btn" data-vtype="camion" onclick="selectVType('camion')">🚚 Camion</div>
      <div class="choice-btn" data-vtype="scooter" onclick="selectVType('scooter')">🛵 Scooter</div>
      <div class="choice-btn" data-vtype="moto" onclick="selectVType('moto')">🏍️ Moto</div>
      <div class="choice-btn" data-vtype="tracteur" onclick="selectVType('tracteur')">🚜 Tracteur/Util.</div>
    </div>
    <label>Récurrence vidange (km, optionnel)</label>
    <input type="text" inputmode="numeric" id="v-int-vidange" placeholder="Ex : 15000">
    <label>Récurrence pneus (km, optionnel)</label>
    <input type="text" inputmode="numeric" id="v-int-pneus" placeholder="Ex : 40000">
    <div id="v-chaine-zone" style="display:none;">
      <label>Récurrence graissage chaîne (km, optionnel)</label>
      <input type="text" inputmode="numeric" id="v-int-chaine" placeholder="Ex : 500">
    </div>
    <label>Date du prochain contrôle technique (optionnel)</label>
    <input type="date" id="v-date-ct">
    <label>Date de renouvellement assurance (optionnel)</label>
    <input type="date" id="v-date-assurance">
    <button class="btn btn-garage" style="margin-top:16px;" onclick="createVehicule()">Créer le véhicule</button>
  </div>
</div>

<div class="modal-overlay" id="modal-edit-vehicule">
  <div class="modal-box">
    <div class="modal-header"><h2>Modifier le véhicule</h2><div class="close-x" onclick="closeModal('modal-edit-vehicule')">✕</div></div>
    <label>Marque</label>
    <input type="text" id="e-marque">
    <label>Modèle</label>
    <input type="text" id="e-modele">
    <label>Immatriculation</label>
    <input type="text" id="e-immat">
    <label>Année de mise en service</label>
    <input type="text" inputmode="numeric" id="e-annee">
    <label>Prix d'achat (optionnel)</label>
    <input type="text" inputmode="decimal" id="e-prix">
    <label>Type de véhicule</label>
    <div class="sub-grid" id="edit-type-grid">
      <div class="choice-btn" data-evtype="voiture" onclick="selectEVType('voiture')">🚘 Voiture</div>
      <div class="choice-btn" data-evtype="camion" onclick="selectEVType('camion')">🚚 Camion</div>
      <div class="choice-btn" data-evtype="scooter" onclick="selectEVType('scooter')">🛵 Scooter</div>
      <div class="choice-btn" data-evtype="moto" onclick="selectEVType('moto')">🏍️ Moto</div>
      <div class="choice-btn" data-evtype="tracteur" onclick="selectEVType('tracteur')">🚜 Tracteur/Util.</div>
    </div>
    <label>Récurrence vidange (km, optionnel)</label>
    <input type="text" inputmode="numeric" id="e-int-vidange">
    <label>Récurrence pneus (km, optionnel)</label>
    <input type="text" inputmode="numeric" id="e-int-pneus">
    <div id="e-chaine-zone" style="display:none;">
      <label>Récurrence graissage chaîne (km, optionnel)</label>
      <input type="text" inputmode="numeric" id="e-int-chaine">
    </div>
    <label>Date du prochain contrôle technique (optionnel)</label>
    <input type="date" id="e-date-ct">
    <label>Date de renouvellement assurance (optionnel)</label>
    <input type="date" id="e-date-assurance">
    <button class="btn btn-garage" style="margin-top:16px;" onclick="saveEditVehicule()">Enregistrer les modifications</button>
  </div>
</div>

<div class="modal-overlay" id="modal-depense">
  <div class="modal-box">
    <div class="modal-header"><h2>Nouvelle dépense</h2><div class="close-x" onclick="closeModal('modal-depense')">✕</div></div>

    <label>Type</label>
    <div class="type-choice">
      <div class="choice-btn" data-val="carburant" onclick="selectType('carburant')">⛽ Carburant</div>
      <div class="choice-btn" data-val="entretien" onclick="selectType('entretien')">🔧 Entretien</div>
    </div>

    <div id="sub-type-zone" style="display:none;">
      <label>Type d'entretien (plusieurs choix possibles)</label>
      <div class="sub-grid">
        <div class="choice-btn" data-sub="pneus" onclick="selectSub('pneus')">🛞 Pneus</div>
        <div class="choice-btn" data-sub="vidange" onclick="selectSub('vidange')">🛢️ Vidange</div>
