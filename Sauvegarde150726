function kmAtOrBefore(vehicleId, dateStr){
  const logs = data.kmLogs.filter(k=>k.vehicleId===vehicleId && k.date<=dateStr).sort((a,b)=>a.date.localeCompare(b.date));
  if(logs.length===0){
    const v = data.vehicles.find(x=>x.id===vehicleId);
    return v ? v.kmInitial : 0;
  }
  return logs[logs.length-1].km;
}
function renderKPI(){
  const v = data.vehicles.find(x=>x.id===currentVehicleId);
  if(!v) return;
  let start = document.getElementById('kpi-start').value;
  let end = document.getElementById('kpi-end').value;
  const allExp = data.expenses.filter(e=>e.vehicleId===currentVehicleId);
  if(!start || !end){
    const dates = allExp.map(e=>e.date).sort();
    start = dates.length ? dates[0] : todayStr();
    end = todayStr();
    document.getElementById('kpi-start').value = start;
    document.getElementById('kpi-end').value = end;
  }
  const filtered = allExp.filter(e=> e.date>=start && e.date<=end);
  const total = filtered.reduce((s,e)=>s+e.cout,0);
  const kmStart = kmAtOrBefore(v.id, start);
  const kmEnd = kmAtOrBefore(v.id, end);
  const kmDelta = Math.max(kmEnd - kmStart, 0);
  const coutKm = kmDelta > 0 ? total/kmDelta : 0;

  document.getElementById('kpi-cout-total').textContent = fmtMoney(total);
  document.getElementById('kpi-cout-km').textContent = fmtMoney(coutKm);

  const subs = ['pneus','vidange','plaquettes','disques','autre'];
  if(v.type==='moto') subs.push('chaine');
  const icons = {pneus:'🛞', vidange:'🛢️', plaquettes:'🅿️', disques:'💿', autre:'➕', chaine:'⚙️'};
  const zone = document.getElementById('kpi-timelines');
  zone.innerHTML = subs.map(s=>{
    const entries = allExp.filter(e=> (e.subtypes && e.subtypes.includes(s)) || e.subtype===s)
      .sort((a,b)=>a.date.localeCompare(b.date));
    if(entries.length===0){
      return `<div class="timeline-block"><div class="timeline-title">${icons[s]} ${subLabel(s)}</div>
        <div class="timeline-entry"><span>Aucune donnée</span></div></div>`;
    }
    let rows = '';
    for(let i=0;i<entries.length;i++){
      const cur = entries[i];
      if(i===0){
        rows += `<div class="timeline-entry"><span>${formatDate(cur.date)} · ${cur.km.toLocaleString('fr-FR')} km</span><span>—</span></div>`;
      } else {
        const prev = entries[i-1];
        const days = Math.round((new Date(cur.date) - new Date(prev.date))/86400000);
        const kmDiff = cur.km - prev.km;
        rows += `<div class="timeline-entry"><span>${formatDate(cur.date)} · ${cur.km.toLocaleString('fr-FR')} km</span><span>+${days}j / +${kmDiff.toLocaleString('fr-FR')}km</span></div>`;
      }
    }
    return `<div class="timeline-block"><div class="timeline-title">${icons[s]} ${subLabel(s)}</div>${rows}</div>`;
  }).join('');
}

